generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum EstadoGeneral {
  ACTIVO
  INACTIVO
}

enum TipoMovimientoInventario {
  ENTRADA_COMPRA
  SALIDA_VENTA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  SALIDA_PEDIDO
}

enum EstadoCompra {
  REGISTRADA
  ANULADA
}

enum TipoCliente {
  MINORISTA
  CONSTRUCTOR
  ELECTRICISTA
  MAYORISTA
  EMPRESA
}

enum MetodoPago {
  EFECTIVO
  QR
  TARJETA
  TRANSFERENCIA
}

enum EstadoVenta {
  REGISTRADA
  ANULADA
}

enum OrigenPedido {
  WHATSAPP
  WEB
  MOVIL
  PRESENCIAL
}

enum EstadoPedido {
  PENDIENTE
  CONFIRMADO
  PREPARANDO
  EN_REPARTO
  ENTREGADO
  CANCELADO
}

enum EstadoEntrega {
  PENDIENTE
  EN_CAMINO
  ENTREGADA
  FALLIDA
}

enum TipoAlerta {
  STOCK_BAJO
  DESABASTECIMIENTO
  ALTA_DEMANDA
  DOCUMENTO_VENCIDO
}

enum EstadoAlerta {
  PENDIENTE
  ATENDIDA
  IGNORADA
}

enum TipoDocumento {
  MANUAL_TECNICO
  FICHA_SEGURIDAD
  CERTIFICADO_CALIDAD
  GARANTIA
  CONTRATO_PROVEEDOR
  FACTURA_ESCANEADA
  COMPROBANTE_ENTREGA
}

enum EstadoBlockchain {
  PENDIENTE
  REGISTRADO
  ERROR
}

model Usuario {
  idUsuario     Int           @id @default(autoincrement())
  nombre        String
  apellido      String
  email         String        @unique
  password      String
  telefono      String?
  estado        EstadoGeneral @default(ACTIVO)
  fechaCreacion DateTime      @default(now())

  roles                 UsuarioRol[]
  movimientosInventario MovimientoInventario[]
  compras               Compra[]
  ventas                Venta[]
  pedidosRegistrados    Pedido[]
  entregas              Entrega[]

  @@map("usuarios")
}

model Rol {
  idRol       Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  usuarios UsuarioRol[]

  @@map("roles")
}

model UsuarioRol {
  idUsuarioRol Int @id @default(autoincrement())
  idUsuario    Int
  idRol        Int

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario])
  rol     Rol     @relation(fields: [idRol], references: [idRol])

  @@unique([idUsuario, idRol])
  @@map("usuario_rol")
}

model Categoria {
  idCategoria Int           @id @default(autoincrement())
  nombre      String        @unique
  descripcion String?
  estado      EstadoGeneral @default(ACTIVO)

  productos Producto[]

  @@map("categorias")
}

model Marca {
  idMarca     Int           @id @default(autoincrement())
  nombre      String        @unique
  descripcion String?
  estado      EstadoGeneral @default(ACTIVO)

  productos Producto[]

  @@map("marcas")
}

model UnidadMedida {
  idUnidad    Int    @id @default(autoincrement())
  nombre      String
  abreviatura String @unique

  productos Producto[]

  @@map("unidades_medida")
}

model Almacen {
  idAlmacen   Int           @id @default(autoincrement())
  nombre      String
  direccion   String?
  descripcion String?
  estado      EstadoGeneral @default(ACTIVO)

  ubicaciones UbicacionAlmacen[]

  @@map("almacenes")
}

model UbicacionAlmacen {
  idUbicacion Int     @id @default(autoincrement())
  idAlmacen   Int
  pasillo     String?
  estante     String?
  nivel       String?
  descripcion String?

  almacen   Almacen    @relation(fields: [idAlmacen], references: [idAlmacen])
  productos Producto[]

  @@map("ubicaciones_almacen")
}

model Producto {
  idProducto             Int           @id @default(autoincrement())
  idCategoria            Int
  idMarca                Int?
  idUnidad               Int
  idUbicacion            Int?
  codigoBarras           String?       @unique
  nombre                 String
  descripcion            String?
  precioVenta            Decimal       @db.Decimal(10, 2)
  precioCompraReferencia Decimal?      @db.Decimal(10, 2)
  stockActual            Int           @default(0)
  stockMinimo            Int           @default(0)
  estado                 EstadoGeneral @default(ACTIVO)
  fechaCreacion          DateTime      @default(now())

  categoria Categoria         @relation(fields: [idCategoria], references: [idCategoria])
  marca     Marca?            @relation(fields: [idMarca], references: [idMarca])
  unidad    UnidadMedida      @relation(fields: [idUnidad], references: [idUnidad])
  ubicacion UbicacionAlmacen? @relation(fields: [idUbicacion], references: [idUbicacion])

  movimientosInventario MovimientoInventario[]
  detalleCompras        DetalleCompra[]
  detalleVentas         DetalleVenta[]
  detallePedidos        DetallePedido[]
  alertas               Alerta[]
  documentos            Documento[]

  @@map("productos")
}

model MovimientoInventario {
  idMovimiento    Int                      @id @default(autoincrement())
  idProducto      Int
  idUsuario       Int
  tipoMovimiento  TipoMovimientoInventario
  cantidad        Int
  stockAnterior   Int
  stockNuevo      Int
  motivo          String?
  fechaMovimiento DateTime                 @default(now())

  producto Producto @relation(fields: [idProducto], references: [idProducto])
  usuario  Usuario  @relation(fields: [idUsuario], references: [idUsuario])

  @@map("movimientos_inventario")
}

model Proveedor {
  idProveedor   Int           @id @default(autoincrement())
  nombre        String
  nit           String?
  telefono      String?
  email         String?
  direccion     String?
  estado        EstadoGeneral @default(ACTIVO)
  fechaRegistro DateTime      @default(now())

  compras    Compra[]
  documentos Documento[]

  @@map("proveedores")
}

model Compra {
  idCompra    Int          @id @default(autoincrement())
  idProveedor Int
  idUsuario   Int
  fechaCompra DateTime     @default(now())
  total       Decimal      @db.Decimal(10, 2)
  estado      EstadoCompra @default(REGISTRADA)
  observacion String?

  proveedor Proveedor       @relation(fields: [idProveedor], references: [idProveedor])
  usuario   Usuario         @relation(fields: [idUsuario], references: [idUsuario])
  detalles  DetalleCompra[]

  @@map("compras")
}

model DetalleCompra {
  idDetalleCompra Int     @id @default(autoincrement())
  idCompra        Int
  idProducto      Int
  cantidad        Int
  precioUnitario  Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(10, 2)

  compra   Compra   @relation(fields: [idCompra], references: [idCompra])
  producto Producto @relation(fields: [idProducto], references: [idProducto])

  @@map("detalle_compras")
}

model Cliente {
  idCliente     Int           @id @default(autoincrement())
  nombre        String
  apellido      String?
  nitCi         String?
  telefono      String?
  email         String?
  direccion     String?
  tipoCliente   TipoCliente   @default(MINORISTA)
  estado        EstadoGeneral @default(ACTIVO)
  fechaRegistro DateTime      @default(now())

  ventas  Venta[]
  pedidos Pedido[]

  @@map("clientes")
}

model Venta {
  idVenta     Int         @id @default(autoincrement())
  idCliente   Int?
  idUsuario   Int
  fechaVenta  DateTime    @default(now())
  total       Decimal     @db.Decimal(10, 2)
  metodoPago  MetodoPago
  estado      EstadoVenta @default(REGISTRADA)
  observacion String?

  cliente  Cliente?       @relation(fields: [idCliente], references: [idCliente])
  usuario  Usuario        @relation(fields: [idUsuario], references: [idUsuario])
  detalles DetalleVenta[]

  @@map("ventas")
}

model DetalleVenta {
  idDetalleVenta Int     @id @default(autoincrement())
  idVenta        Int
  idProducto     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  venta    Venta    @relation(fields: [idVenta], references: [idVenta])
  producto Producto @relation(fields: [idProducto], references: [idProducto])

  @@map("detalle_ventas")
}

model Pedido {
  idPedido          Int          @id @default(autoincrement())
  idCliente         Int?
  idUsuarioRegistro Int?
  origen            OrigenPedido
  fechaPedido       DateTime     @default(now())
  estado            EstadoPedido @default(PENDIENTE)
  totalEstimado     Decimal?     @db.Decimal(10, 2)
  observacion       String?

  cliente         Cliente?        @relation(fields: [idCliente], references: [idCliente])
  usuarioRegistro Usuario?        @relation(fields: [idUsuarioRegistro], references: [idUsuario])
  detalles        DetallePedido[]
  entrega         Entrega?

  @@map("pedidos")
}

model DetallePedido {
  idDetallePedido Int     @id @default(autoincrement())
  idPedido        Int
  idProducto      Int
  cantidad        Int
  precioEstimado  Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [idPedido], references: [idPedido])
  producto Producto @relation(fields: [idProducto], references: [idProducto])

  @@map("detalle_pedidos")
}

model Entrega {
  idEntrega        Int           @id @default(autoincrement())
  idPedido         Int           @unique
  idRepartidor     Int?
  fechaSalida      DateTime?
  fechaEntrega     DateTime?
  estado           EstadoEntrega @default(PENDIENTE)
  direccionEntrega String
  latitudEntrega   Decimal?      @db.Decimal(10, 7)
  longitudEntrega  Decimal?      @db.Decimal(10, 7)
  fotoEvidenciaUrl String?
  observacion      String?

  pedido     Pedido   @relation(fields: [idPedido], references: [idPedido])
  repartidor Usuario? @relation(fields: [idRepartidor], references: [idUsuario])

  @@map("entregas")
}

model Alerta {
  idAlerta      Int          @id @default(autoincrement())
  idProducto    Int?
  tipoAlerta    TipoAlerta
  mensaje       String
  estado        EstadoAlerta @default(PENDIENTE)
  fechaCreacion DateTime     @default(now())
  fechaAtencion DateTime?

  producto Producto? @relation(fields: [idProducto], references: [idProducto])

  @@map("alertas")
}

model Documento {
  idDocumento      Int           @id @default(autoincrement())
  idProducto       Int?
  idProveedor      Int?
  nombre           String
  tipoDocumento    TipoDocumento
  urlArchivo       String
  fechaCarga       DateTime      @default(now())
  fechaVencimiento DateTime?
  estado           EstadoGeneral @default(ACTIVO)

  producto  Producto?  @relation(fields: [idProducto], references: [idProducto])
  proveedor Proveedor? @relation(fields: [idProveedor], references: [idProveedor])

  @@map("documentos")
}

model RegistroBlockchain {
  idRegistro    Int              @id @default(autoincrement())
  tipoDocumento String
  idReferencia  Int
  hashDocumento String
  redBlockchain String?
  txHash        String?
  fechaRegistro DateTime         @default(now())
  estado        EstadoBlockchain @default(PENDIENTE)

  @@map("registros_blockchain")
}
